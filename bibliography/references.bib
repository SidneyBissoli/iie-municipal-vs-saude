@misc{chaisemartinetal2025differenceindifferencesestimatorstreatments,
  title = {Difference-in-{{Differences Estimators}} for {{Treatments Continuously Distributed}} at {{Every Period}}},
  author = {de Chaisemartin, Cl{\'e}ment and D'Haultf{\oe}uille, Xavier and Pasquier, F{\'e}lix and Sow, Doulo and {Vazquez-Bare}, Gonzalo},
  year = 2025,
  month = aug,
  number = {arXiv:2201.06898},
  eprint = {2201.06898},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2201.06898},
  urldate = {2026-05-03},
  abstract = {When one studies the effects of taxes, tariffs, or prices using panel data, the treatment is often continuously distributed in every period. We propose difference-in-differences (DID) estimators for such cases. We assume that between consecutive periods, the treatment of some units, the switchers, changes, while the treatment of other units, the stayers, remains constant. We show that under a parallel-trends assumption, the slopes of switchers' potential outcomes are nonparametrically identified by difference-in-differences estimands comparing the outcome evolutions of switchers and stayers with the same baseline treatment. Controlling for the baseline treatment ensures that our estimands remain valid if the treatment's effect changes over time. We consider two weighted averages of switchers' slopes, and discuss their respective advantages. For each weighted average, we propose a doubly-robust, nonparametric, and \$\textbackslash sqrt\textbraceleft n\textbraceright\$-consistent estimator. We generalize our results to the instrumental-variable case. We apply our method to estimate the price-elasticity of gasoline consumption.},
  archiveprefix = {arXiv},
  keywords = {Economics - Econometrics},
  file = {C\:\\Users\\SIDNEY\\Zotero\\storage\\Z7B69J8G\\Chaisemartin et al. - 2025 - Difference-in-Differences Estimators for Treatments Continuously Distributed at Every Period.pdf;C\:\\Users\\SIDNEY\\Zotero\\storage\\8AJG2FK6\\2201.html}
}

